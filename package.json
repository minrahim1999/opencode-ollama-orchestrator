{
  "name": "opencode-ollama-orchestrator",
  "version": "1.1.0",
  "description": "Multi-agent orchestrator for OpenCode, hard-locked to Ollama. Automatic mission mode with per-project plan/todo scoping.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "docs",
    "examples"
  ],
  "keywords": [
    "opencode-plugin",
    "opencode",
    "ollama",
    "orchestrator",
    "multi-agent",
    "subagent",
    "ollama-only"
  ],
  "license": "MIT",
  "author": "muhaimin <muhaimin@example.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:minrahim1999/opencode-ollama-orchestrator.git"
  },
  "bugs": {
    "url": "https://github.com/minrahim1999/opencode-ollama-orchestrator/issues"
  },
  "homepage": "https://github.com/minrahim1999/opencode-ollama-orchestrator#readme",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.17.0",
    "@opencode-ai/sdk": ">=1.17.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.7",
    "@opencode-ai/sdk": "^1.17.7",
    "@types/node": "^22.19.21",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "echo 'Lint: add eslint or biome when ready'",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run clean \u0026\u0026 npm run build"
  },
  "engines": {
    "node": ">=20"
  }
}
